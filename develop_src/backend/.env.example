# Anthropic API Key (https://console.anthropic.com) - 미사용 시 비워두세요
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL 연결 설정
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_ai
DB_USER=postgres
DB_PASSWORD=****

# 서버 포트
PORT=3000

# data_src 폴더 절대경로 (기본값: 프로젝트 루트의 data_src)
# DATA_SRC_PATH=/your/path/to/data_src
